# ---------------------------------------------------------------------------
# .gitattributes
#
# export-ignore — paths listed here are stripped from the automatic
# "Source code (zip/tar.gz)" archives GitHub generates for every release tag,
# and from any `git archive` export used to build the distributable zip.
#
# RULE: if it's not needed by the plugin at runtime, exclude it.
# ---------------------------------------------------------------------------

# --- Dev tooling ---
dev/                        export-ignore

# --- Tests ---
tests/                      export-ignore

# --- Build artefacts (belt-and-braces) ---
build/                      export-ignore
coverage/                   export-ignore

# --- Git & CI config ---
.gitattributes              export-ignore
.gitignore                  export-ignore
.github/                    export-ignore
.editorconfig               export-ignore

# --- Editor / IDE ---
.vscode/                    export-ignore
.idea/                      export-ignore

# --- Developer documentation ---
CONTRIBUTING.md             export-ignore
SECURITY.md                 export-ignore
CHANGELOG.md                export-ignore

# --- Line endings: always LF in the repo ---
* text=auto eol=lf
*.php  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.xml  text eol=lf
*.neon text eol=lf

# --- Binary files: never diff or merge ---
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.mo   binary
*.zip  binary
