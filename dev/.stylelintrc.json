{
    "extends": [
        "@wordpress/stylelint-config"
    ],
    "rules": {
        "no-descending-specificity": null,
        "no-duplicate-selectors": null,
        "selector-class-pattern": [
            "^[a-z][a-z0-9]*(-[a-z0-9]+)*(__[a-z][a-z0-9]*(-[a-z0-9]+)*)?(--[a-z][a-z0-9]*(-[a-z0-9]+)*)?$",
            {
                "message": "Selector should be kebab-case, optionally with a BEM __element and/or --modifier (selector-class-pattern)"
            }
        ]
    },
    "ignoreFiles": [
        "vendor/**",
        "node_modules/**",
        "build/**",
        "coverage/**",
        "**/*.min.css"
    ]
}
