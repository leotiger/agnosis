{
    "extends": [
        "@wordpress/stylelint-config"
    ],
    "rules": {
        "no-descending-specificity": null,
        "no-duplicate-selectors": null,
        "scss/at-rule-no-unknown": null
    },
    "ignoreFiles": [
        "vendor/**",
        "node_modules/**",
        "build/**",
        "**/*.min.css"
    ]
}
