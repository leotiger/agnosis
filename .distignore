# Files excluded from the distributable plugin ZIP.
# This file is read by dev/bin/build-zip.sh (rsync-based).
# Any path listed here is kept in the repo but stripped from the ZIP.

# Repo documentation and WordPress.org assets
docs/

# Developer / project documentation
SECURITY.md
CONTRIBUTING.md
CHANGELOG.md
README.md
CLAUDE.md
REVIEW.md

# Git and CI
.git
.gitignore
.gitattributes
.github/
.distignore

# Editor and IDE
.editorconfig
.vscode/
.idea/
.DS_Store

# Git placeholder files — real directories don't need these in a ZIP
.gitkeep

# Dev tooling — all tooling lives under dev/
dev/

# Strauss (dependency-prefixing tool, C-item/§4e) — build-time only; the
# strauss.phar binary has no runtime purpose.
bin/

# Strauss's dev-time backward-compat shim (see Strauss's own README): lets
# code still using the un-prefixed class names keep working locally during
# the transition, but must never ship — production code should only ever
# resolve the real, prefixed classes in vendor-prefixed/.
vendor/composer/autoload_aliases.php

# Composer-generated CLI shims (e.g. vendor/bin/carbon) for dependencies that
# Strauss's delete_vendor_packages has moved to vendor-prefixed/ — Strauss
# only deletes the package's own vendor/<vendor>/<package> directory, not
# these separately-generated wrapper scripts, so they'd otherwise ship as
# dangling references to a now-deleted file. No WP plugin runtime code needs
# vendor/bin/.
vendor/bin/

# Tests
tests/
build/
coverage/

# Belt-and-braces — dev config files that shouldn't ship
node_modules/
package.json
package-lock.json
.eslintrc.json
.prettierrc.json
.stylelintrc.json
.wp-env.json
.wp-env.override.json
.wp-env/
composer.lock
phpcs.xml
phpcs.xml.dist
.phpcs.xml
.phpcs.cache
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache
phpstan.neon
phpstan.neon.dist
.phpstan.cache
