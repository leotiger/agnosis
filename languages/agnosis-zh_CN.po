msgstr "— 未设置 —"

#: includes/Publishing/ReviewConfirm.php:956
msgid "Discard this submission?"
msgstr "要丢弃此提交吗？"

#: includes/Publishing/ReviewConfirm.php:957
msgid ""
"This will permanently discard the submission — it will not be published."
msgstr "这将永久丢弃该提交——它不会被发布。"

#: includes/Publishing/ReviewConfirm.php:958
msgid "Yes, discard it"
msgstr "是的，丢弃它"

#: includes/Publishing/ReviewConfirm.php:961
msgid "Remove this artwork?"
msgstr "要移除此作品吗？"

