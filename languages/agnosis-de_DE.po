msgstr "Wir haben eine Anfrage zum Entfernen des folgenden %s erhalten:"

#. translators: %s: "artwork" or "event"
#: includes/Publishing/Notification.php:585
#, php-format
msgid ""
"If you want to permanently remove this %s, click the button below. This "
