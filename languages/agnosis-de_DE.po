#. translators: 1: voter display name, 2: site name, 3: closing date, 4: yes URL, 5: no URL
#: includes/Artist/DepartureNotification.php:311
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"The %2$s community has opened a vote to remove a member. The vote closes on "
"%3$s.\n"
"\n"
"Cast your vote:\n"
"\n"
"Vote YES (remove): %4$s\n"
"\n"
"Vote NO (keep):    %5$s\n"
"\n"
"A majority of active members (more than 50%%) must vote yes for the removal "
"to proceed. You can change your vote by clicking the other link before the "
"deadline.\n"
"\n"
"— %2$s"
msgstr ""
"Hallo %1$s,\n"
"\n"
"Die %2$s-Community hat eine Abstimmung eröffnet, um ein Mitglied zu "
"entfernen. Die Abstimmung endet am %3$s.\n"
"\n"
"Gib deine Stimme ab:\n"
"\n"
"JA stimmen (entfernen): %4$s\n"
"\n"
"NEIN stimmen (behalten): %5$s\n"
"\n"
"Eine Mehrheit der aktiven Mitglieder (mehr als 50%%) muss mit Ja stimmen, "
"damit die Entfernung weitergehen kann. Du kannst deine Stimme ändern, indem "
"du vor Ablauf der Frist auf den anderen Link klickst.\n"
"\n"
"— %2$s"

