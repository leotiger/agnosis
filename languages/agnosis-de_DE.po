msgid ""
"Force-reprocess complete. %1$d queue row(s) reset, %2$d new message(s) "
"enqueued. Click \"Process Pending Queue\" to run the AI pipeline."
msgstr ""
"Erneutes Verarbeiten abgeschlossen. %d Zeilen in der Warteschlange wurden "
"zurückgesetzt, %d neue Nachrichten in die Warteschlange gestellt. Klicke auf "
"\"Verarbeitungswarteschlange bearbeiten\", um die KI-Pipeline auszuführen."

#: includes/Admin/Settings.php:88
msgid "Log cleared."
msgstr "Protokoll gelöscht."

#. translators: %d: number of queue items processed
