msgstr "Ombi lako kwa %s"

#. translators: %s: applicant display name
#: includes/Artist/AdmissionNotification.php:257
#, php-format
msgid "Application by %s has closed"
msgstr "Ombi la %s limefungwa"

#. translators: %s: community name
#: includes/Artist/AdmissionNotification.php:297
#, php-format
