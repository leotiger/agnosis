#~ "— %2$s"
#~ msgstr ""
#~ "%1$s amethibitisha kuondoka kwao kutoka %2$s.\n"
#~ "\n"
#~ "Akaunti yao na kazi zote zilizochapishwa zimefutwa kabisa.\n"
#~ "\n"
#~ "— %2$s"

