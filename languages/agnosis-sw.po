#: includes/Artist/AdmissionNotification.php:792
#: includes/Artist/CommunityBroadcast.php:183
#: includes/Artist/CommunityBroadcast.php:251
#: includes/Artist/CommunityCapNotification.php:86
#: includes/Artist/DepartureNotification.php:95
#: includes/Artist/DepartureNotification.php:221
