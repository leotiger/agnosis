#: includes/Artist/DepartureNotification.php:69
#, php-format
msgid "Confirm your departure from %s"
msgstr "Thibitisha kuondoka kwako kutoka %s"

#. translators: 1: artist display name, 2: site name, 3: confirmation URL
#: includes/Artist/DepartureNotification.php:74
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"We received a request to remove your account and all your published work "
"from %2$s.\n"
"\n"
"If you made this request, click the link below to confirm. This action is "
"permanent and cannot be undone.\n"
"\n"
"%3$s\n"
"\n"
"If you did not make this request, you can ignore this email — your account "
"remains unchanged.\n"
"\n"
"— %2$s"
msgstr ""
"Habari %1$s,\n"
"\n"
"Tumepokea ombi la kufuta akaunti yako na kazi zako zote zilizochapishwa "
"kutoka %2$s.\n"
"\n"
"Iwapo wewe ndiye uliyeweka ombi hili, bofya kiungo kilicho hapa chini "
"kuthibitisha. Hatua hii ni ya kudumu na haiwezi kutenduliwa.\n"
"\n"
"%3$s\n"
"\n"
"Ikiwa hukutoa ombi hili, unaweza kupuuza barua pepe hii — akaunti yako "
"itabaki bila mabadiliko.\n"
"\n"
"— %2$s"

#. translators: %s: site name
#: includes/Artist/DepartureNotification.php:137
#, php-format
msgid "An artist has left %s"
msgstr "Msanii ameondoka %s"

#. translators: 1: artist display name, 2: site name
#: includes/Artist/DepartureNotification.php:142
#, php-format
msgid ""
"%1$s has confirmed their departure from %2$s.\n"
"\n"
"Their account and all published work have been permanently deleted.\n"
"\n"
"— %2$s"
msgstr ""
"%1$s amethibitisha kuondoka kwake kutoka %2$s.\n"
"\n"
"Akaunti yake na kazi zote zilizochapishwa zimefutwa kabisa na kwa kudumu.\n"
"\n"
"— %2$s"

#. translators: %s: site name
#: includes/Artist/DepartureNotification.php:166
#, php-format
msgid "You've left %s"
msgstr ""

#. translators: 1: artist display name, 2: site name
#: includes/Artist/DepartureNotification.php:171
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
