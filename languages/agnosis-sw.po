msgstr "Kiungo si sahihi au hakijakamilika."

#: includes/Artist/AdmissionConfirm.php:80
#: includes/Newsletter/SubscriptionConfirm.php:158
msgid "This confirmation link is invalid or has already been used."
msgstr "Kiungo hiki cha uthibitisho si sahihi au tayari kimetumiwa."

#: includes/Artist/AdmissionConfirm.php:113
msgid "Confirming your application…"
msgstr "Inathibitisha ombi lako…"

#: includes/Artist/AdmissionConfirm.php:114
msgid "Hang tight — we're opening your application for community review."
msgstr "Subiri kidogo — tunafungua ombi lako kwa ukaguzi wa jamii."

#: includes/Artist/AdmissionConfirm.php:115
#: includes/Artist/AdmissionNotification.php:404
msgid "Confirm my application"
msgstr "Thibitisha ombi langu"

#: includes/Artist/AdmissionConfirm.php:153
msgid ""
"This community is currently full, so your application has joined the "
"waitlist — when a member leaves, the next person in line is welcomed in."
msgstr ""
"Jamii hii imejaa kwa sasa, kwa hiyo ombi lako limeingizwa kwenye orodha ya "
"kusubiri — mwanajamii akiondoka, mtu anayefuata kwenye foleni anaingizwa."

#: includes/Artist/AdmissionConfirm.php:154
msgid ""
"You're all set — the community can now review your application and vote."
msgstr "Umefikia — sasa jamii inaweza kukagua ombi lako na kupiga kura."

#: includes/Artist/AdmissionConfirm.php:157
msgid "Application confirmed"
msgstr "Ombi limethibitishwa"

#. translators: %s: applicant's display name
#: includes/Artist/AdmissionConfirm.php:160
#, php-format
msgid "Thanks, %s!"
msgstr "Asante, %s!"

#: includes/Artist/AdmissionConfirm.php:169
