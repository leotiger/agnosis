msgstr "Tumepokea ombi lako kwa %s"

#. translators: %s: recipient's display name
#: includes/Artist/AdmissionNotification.php:392
#: includes/Artist/AdmissionNotification.php:438
#: includes/Artist/AdmissionNotification.php:594
