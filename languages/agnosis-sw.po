msgid "popover"
msgstr "dirisha ibukizi"

#: blocks/newsletter-popover/block.json
msgctxt "block keyword"
msgid "footer"
msgstr "chini ya ukurasa"

#: blocks/newsletter-signup/block.json
msgctxt "block title"
msgid "Newsletter Signup"
msgstr "Usajili wa Jarida la Barua"

#: blocks/newsletter-signup/block.json
msgctxt "block description"
msgid ""
"Email signup form for the public newsletter (double opt-in). Submits to the "
"newsletter subscribe REST endpoint."
msgstr ""
"Fomu ya kujisajili kwa barua pepe kwa jarida la barua la umma (uthibitisho "
"wa hatua mbili). Hutuma kwa endpoint ya REST ya kujisajili kwa jarida la "
"barua."

