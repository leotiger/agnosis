#: blocks/join/block.json
msgctxt "block title"
msgid "Join Agnosis"
msgstr "Jiunge na Agnosis"

#: blocks/join/block.json
msgctxt "block description"
msgid ""
"Public application form for artists who want to join the Agnosis network. "
"Submits to the admission REST endpoint. Place this on your /join/ page."
msgstr ""
"Fomu ya maombi ya umma kwa wasanii wanaotaka kujiunga na mtandao wa Agnosis. "
"Hutumwa kwenye kiolesura cha REST cha udahili. Weka hii kwenye ukurasa wako "
"wa /join/."

