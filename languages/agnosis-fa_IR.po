msgstr "رویداد منتشر شده است."

#: includes/Publishing/ReviewConfirm.php:298
msgid "Artwork published"
msgstr "اثر هنری منتشر شد"

#: includes/Publishing/ReviewConfirm.php:298
msgid "The artwork has been published to the gallery."
msgstr "اثر هنری در گالری منتشر شد."

#: includes/Publishing/ReviewConfirm.php:299
msgid "Submission discarded"
msgstr "ارسال حذف شد"

#: includes/Publishing/ReviewConfirm.php:299
