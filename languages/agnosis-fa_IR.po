#. translators: 1: sender's display name, 2: character count of their message,
#. 3: configured character limit, 4: site name
#: includes/Artist/CommunityBroadcast.php:158
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"Your message to the community was %2$d characters long — the current limit is %3$d. It was not sent to anyone.\n"
"\n"
"Every recipient's copy is translated individually into their own language, so a very long message is costly to translate for the whole community. Please shorten it and send it again.\n"
"\n"
"— %4$s"
msgstr ""
"سلام %1$s،\n"
"\n"
"پیام شما به جامعه %2$d نویسه داشت — حد فعلی %3$d است. این پیام برای هیچ‌کس ارسال نشد.\n"
"\n"
"نسخهٔ هر گیرنده به‌طور جداگانه به زبان خودش ترجمه می‌شود، بنابراین پیام بسیار طولانی برای ترجمهٔ کل جامعه هزینه‌بر است. لطفاً آن را کوتاه‌تر کنید و دوباره بفرستید.\n"
"\n"
"— %4$s"

#. translators: %s: site name
#: includes/Artist/CommunityBroadcast.php:210
#, php-format
msgid "[%s] Your community message was not sent — no content found"
msgstr "[%s] پیام جامعهٔ شما ارسال نشد — محتوایی پیدا نشد"

#. translators: 1: sender's display name, 2: site name
#: includes/Artist/CommunityBroadcast.php:216
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"Your message to the community had no subject or message text that could be found — this often happens when an email client sends an HTML-only message with no plain-text version included. It was not sent to anyone.\n"
"\n"
"Please try sending it again with plain text included.\n"
"\n"
"— %2$s"
msgstr ""
"سلام %1$s،\n"
"\n"
"در پیام شما به جامعه، نه موضوعی پیدا شد و نه متن پیامی — این معمولاً وقتی رخ می‌دهد که یک کلاینت ایمیل فقط پیام HTML بفرستد و نسخهٔ متنیِ ساده‌ای همراه آن نباشد. این پیام برای هیچ‌کس ارسال نشد.\n"
"\n"
"لطفاً دوباره آن را با متن سادهٔ همراه ارسال کنید.\n"
"\n"
"— %2$s"

