msgstr "عمومی"

#: includes/Admin/Settings.php:160
msgid "Email Inbox"
msgstr "صندوق پستی ایمیل"

#: includes/Admin/Settings.php:161
msgid "AI Providers"
msgstr "ارائه‌دهندگان هوش مصنوعی"

#: includes/Admin/Settings.php:162
msgid "Behaviour"
msgstr "رفتار"

#: includes/Admin/Settings.php:163
