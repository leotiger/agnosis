"نگارشی را با فهرست بالا دوباره بررسی کنید."

#. translators: %s: artwork title
#: includes/Publishing/Notification.php:445
#, php-format
msgid "\"%s\" is now your featured artwork on the gallery overview."
msgstr "«%s» اکنون به‌عنوان اثر هنری برجسته شما در نمای کلی گالری است."

#: includes/Publishing/Notification.php:451
msgid ""
"Any previously featured artwork has been unfeatured automatically — only one"
