#. translators: 1: artist display name, 2: site name, 3: confirmation URL
#: includes/Artist/DepartureNotification.php:74
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"We received a request to remove your account and all your published work from %2$s.\n"
"\n"
"If you made this request, click the link below to confirm. This action is permanent and cannot be undone.\n"
"\n"
"%3$s\n"
"\n"
"If you did not make this request, you can ignore this email — your account remains unchanged.\n"
"\n"
"— %2$s"
msgstr ""
"سلام %1$s،\n"
"\n"
"ما درخواست حذف حساب شما و همه آثار منتشرشده‌تان از %2$s را دریافت کردیم.\n"
"\n"
"اگر این درخواست را شما داده‌اید، برای تأیید روی پیوند زیر کلیک کنید. این اقدام دائمی است و نمی‌توان آن را بازگرداند.\n"
"\n"
"%3$s\n"
"\n"
"اگر این درخواست را شما نداده‌اید، می‌توانید این ایمیل را نادیده بگیرید — حساب شما بدون تغییر باقی می‌ماند.\n"
"\n"
"— %2$s"

#. translators: %s: site name
#: includes/Artist/DepartureNotification.php:137
