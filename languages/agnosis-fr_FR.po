#: includes/Admin/Settings.php:34 includes/Admin/Settings.php:35
msgid "Configuration"
msgstr "Configuration"

#. translators: 1: queue rows reset, 2: messages newly enqueued
#: includes/Admin/Settings.php:80
#, php-format
msgid ""
"Force-reprocess complete. %1$d queue row(s) reset, %2$d new message(s) "
"enqueued. Click \"Process Pending Queue\" to run the AI pipeline."
msgstr ""
"Reprocessement forcé terminé. %1$d ligne(s) de la file réinitialisée, %2$d "
"nouveau(x) message(s) mis en file d'attente. Cliquez sur \"Traiter la file "
"en attente\" pour exécuter le pipeline AI."

#: includes/Admin/Settings.php:88
msgid "Log cleared."
msgstr "Journal effacé."

#. translators: %d: number of queue items processed
#: includes/Admin/Settings.php:96
#, php-format
msgid "Processed %d pending queue item(s). Check the Logs tab for details."
msgstr ""
"Traitement de %d élément(s) en attente de la file. Consultez l'onglet "
"Journaux pour plus de détails."

#. translators: %d: number of new messages enqueued
#: includes/Admin/Settings.php:106
#, php-format
msgid ""
"Poll complete. %d new message(s) enqueued. Check the Logs tab, then click "
"Process Pending Queue."
msgstr ""
"Son d'alerte terminé. %d nouveau(x) message(s) mis en file d'attente. "
"Vérifiez l'onglet Journaux, puis cliquez sur Traiter la file en attente."

#: includes/Admin/Settings.php:126
msgid "Art blooming out of oblivion"
msgstr "L'art émergeant de l'oubli"

#: includes/Admin/Settings.php:145
msgid "Save Changes"
msgstr "Enregistrer les modifications"

#: includes/Admin/Settings.php:159
msgid "General"
msgstr "Général"

#: includes/Admin/Settings.php:160
msgid "Email Inbox"
msgstr "Boîte de réception des e-mails"

#: includes/Admin/Settings.php:161
msgid "AI Providers"
msgstr "Fournisseurs d'IA"

#: includes/Admin/Settings.php:162
msgid "Behaviour"
msgstr "Comportement"

#: includes/Admin/Settings.php:163
msgid "Network"
msgstr "Réseau"

#: includes/Admin/Settings.php:164
msgid "Commerce"
msgstr "Commerce"

#: includes/Admin/Settings.php:165
msgid "Logs"
msgstr "Journaux"

#: includes/Admin/Settings.php:226
msgid "Base domain"
msgstr "Domaine de base"

#: includes/Admin/Settings.php:227
msgid ""
"Root domain for artist subdomains, e.g. agnosis.art. Each artist is "
"reachable at nicename.{base_domain}. Requires a wildcard DNS record (*."
"{base_domain}) pointing to this server. Leave blank to disable subdomain "
"routing."
msgstr ""
"Domaine racine pour les sous-domaines des artistes, par exemple agnosis.art. "
"Chaque artiste est accessible à l'adresse nicename.{base_domain}. Nécessite "
"un enregistrement DNS générique (*.{base_domain}) pointant vers ce serveur. "
"Laissez vide pour désactiver le routage par sous-domaine."

#: includes/Admin/Settings.php:232
msgid "Node label"
msgstr "Étiquette du nœud"

#: includes/Admin/Settings.php:233
msgid "How this node introduces itself to the network."
msgstr "Comment ce nœud se présente-t-il au réseau."

#: includes/Admin/Settings.php:240
msgid "Email driver"
msgstr "Pilote de messagerie"

#: includes/Admin/Settings.php:248
msgid "Artwork submissions address"
msgstr "Adresse de soumission des œuvres"

#: includes/Admin/Settings.php:249
msgid "Artists send artwork to this address — e.g. submit@agnosis.art"
msgstr ""
"Les artistes envoient leurs œuvres à cette adresse — par exemple "
"submit@agnosis.art"

#: includes/Admin/Settings.php:253
msgid "Biography submissions address"
msgstr "Adresse de soumission des biographies"

#: includes/Admin/Settings.php:254
msgid "Artists send biography updates to this address — e.g. bio@agnosis.art"
msgstr ""
"Les artistes envoient leurs mises à jour de biographie à cette adresse — par "
"exemple bio@agnosis.art"

#: includes/Admin/Settings.php:258
msgid "Event submissions address"
msgstr "Adresse de soumission d'événements"

#: includes/Admin/Settings.php:259
msgid ""
"Artists send event announcements to this address — e.g. event@agnosis.art"
msgstr ""
"Les artistes envoient leurs annonces d'événements à cette adresse — par "
"exemple event@agnosis.art"

#: includes/Admin/Settings.php:263
msgid "Replace artwork address"
msgstr "Remplacer l'adresse de l'œuvre"

#: includes/Admin/Settings.php:264
msgid ""
"Artist sends a new version of an existing artwork. Subject must match the "
"original title. Bypasses duplicate detection — e.g. replace@agnosis.art"
msgstr ""
"L'artiste envoie une nouvelle version d'une œuvre existante. Le sujet doit "
"correspondre au titre original. Contourne la détection de doublons — par "
"exemple replace@agnosis.art"

#: includes/Admin/Settings.php:268
msgid "Removal request address"
msgstr "Adresse de demande de suppression"

#: includes/Admin/Settings.php:269
msgid ""
"Artist requests takedown of an existing artwork. Subject must match the "
"title. Moves the post to draft pending admin review — e.g. remove@agnosis.art"
msgstr ""
"L'artiste demande la suppression d'une œuvre existante. Le sujet doit "
"correspondre au titre. Déplace le message en brouillon en attente de "
"validation par l'administrateur — par exemple remove@agnosis.art"

#: includes/Admin/Settings.php:275
msgid "IMAP host"
msgstr "Hôte IMAP"

#: includes/Admin/Settings.php:276
msgid "e.g. imap.yourhost.com"
msgstr "par exemple imap.votrehôte.com"

#: includes/Admin/Settings.php:280
msgid "IMAP port"
msgstr "Port IMAP"

#: includes/Admin/Settings.php:287
msgid "Use SSL"
msgstr "Utiliser SSL"

#: includes/Admin/Settings.php:295
msgid "Skip SSL certificate validation"
msgstr "Ignorer la validation du certificat SSL"

#: includes/Admin/Settings.php:300
msgid ""
"⚠ Use only as a temporary workaround when your mail server's certificate is "
"not yet trusted (e.g. Plesk self-signed cert before Let's Encrypt is applied "
"to the mail daemon). Disable this once the mail server presents a valid "
"certificate."
msgstr ""
"⚠ Utiliser uniquement comme solution temporaire lorsque le certificat de "
"votre serveur de messagerie n'est pas encore reconnu (par exemple, "
"certificat auto-signé Plesk avant que Let's Encrypt ne soit appliqué au "
"démon de messagerie). Désactivez ceci une fois que le serveur de messagerie "
"présente un certificat valide."

#: includes/Admin/Settings.php:304
msgid "IMAP username"
msgstr "Nom d'utilisateur IMAP"

#: includes/Admin/Settings.php:305
msgid ""
"Login username for the IMAP account — typically the catch-all mailbox "
"address."
msgstr ""
"Nom d'utilisateur de connexion pour le compte IMAP — généralement l'adresse "
"de la boîte aux lettres catch-all."

#: includes/Admin/Settings.php:309
msgid "Submission email password"
msgstr "Mot de passe de l'e-mail de soumission"

#: includes/Admin/Settings.php:315
msgid "Webhook secret"
msgstr "Secret du webhook"

#: includes/Admin/Settings.php:316
msgid "HMAC secret shared with your webhook provider (Mailgun, SendGrid…)."
msgstr ""
"Secret HMAC partagé avec votre fournisseur de webhook (Mailgun, SendGrid…)."

#: includes/Admin/Settings.php:322
msgid "Inbox retention (days)"
msgstr "Rétention de la boîte de réception (jours)"

#: includes/Admin/Settings.php:328
msgid ""
"Seen IMAP messages and processed/failed queue rows older than this are "
"permanently deleted by the daily cleanup. Default: 7 days."
msgstr ""
"Les messages IMAP lus et les lignes de file traitées/échouées plus anciennes "
"que cette durée sont définitivement supprimés par le nettoyage quotidien. "
"Par défaut : 7 jours."

#: includes/Admin/Settings.php:334
msgid "Description provider"
msgstr "Fournisseur de description"

#: includes/Admin/Settings.php:342
msgid ""
"Analyses the artwork image and writes the title, body, tags and alt text. "
"WordPress AI Services delegates to whichever provider the site has "
"configured via the AI Services plugin."
msgstr ""
"Analyse l'image de l'œuvre et écrit le titre, le corps, les tags et le texte "
"alternatif. Les services AI de WordPress délèguent à celui que le site a "
"configuré via le plugin AI Services."

#: includes/Admin/Settings.php:346
msgid "OpenAI vision model"
msgstr "Modèle de vision OpenAI"

#: includes/Admin/Settings.php:348
msgid ""
"Model used for artwork description when OpenAI is the description provider. "
"Must support vision input."
msgstr ""
"Modèle utilisé pour la description de l'œuvre lorsque OpenAI est le "
"fournisseur de description. Doit supporter l'entrée de vision."

#: includes/Admin/Settings.php:352
msgid "Anthropic model"
msgstr "Modèle Anthropic"

#: includes/Admin/Settings.php:354
msgid ""
"Model used for artwork description when Anthropic is the description "
"provider. Must support vision input."
msgstr ""
"Modèle utilisé pour la description de l'œuvre lorsque Anthropic est le "
"fournisseur de description. Doit supporter l'entrée de vision."

#: includes/Admin/Settings.php:360
msgid "Enhancement provider"
msgstr "Fournisseur d'amélioration"

#: includes/Admin/Settings.php:363
msgid "Auto (OpenAI if key is set)"
msgstr "Auto (OpenAI si la clé est configurée)"

#: includes/Admin/Settings.php:365
msgid "Disabled — use original image"
msgstr "Désactivé — utiliser l'image originale"

#: includes/Admin/Settings.php:368
msgid ""
"Enhances the artwork image before publishing. Uses OpenAI gpt-image-1. Set "
"to Disabled to skip enhancement and publish the original."
msgstr ""
"Améliore l'image de l'œuvre avant publication. Utilise OpenAI gpt-image-1. "
"Mettre sur Désactivé pour sauter l'amélioration et publier l'originale."

#: includes/Admin/Settings.php:372
msgid "OpenAI image model"
msgstr "Modèle d'image OpenAI"

#: includes/Admin/Settings.php:374
msgid ""
"Model used for image enhancement when OpenAI is the enhancement provider."
msgstr ""
"Modèle utilisé pour l'amélioration d'image lorsque OpenAI est le fournisseur "
"d'amélioration."

#: includes/Admin/Settings.php:380
msgid "Polish biography with AI"
msgstr "Polir la biographie avec l'IA"

#: includes/Admin/Settings.php:383
msgid ""
"When enabled, biography submissions are passed through the AI to fix "
"spelling and make minor text improvements before saving."
msgstr ""
"Lorsqu'il est activé, les soumissions de biographie sont traitées par l'IA "
"pour corriger l'orthographe et apporter de légères améliorations au texte "
"avant de sauvegarder."

#: includes/Admin/Settings.php:387
msgid "Polish events with AI"
msgstr "Polir les événements avec l'IA"

#: includes/Admin/Settings.php:390
msgid ""
"When enabled, event submissions are passed through the AI to fix spelling "
"and make minor text improvements before saving."
msgstr ""
"Lorsqu'il est activé, les soumissions d'événements sont traitées par l'IA "
"pour corriger l'orthographe et apporter de légères améliorations au texte "
"avant de sauvegarder."

#: includes/Admin/Settings.php:396
msgid "Enhancement threshold (quality score)"
msgstr "Seuil d'amélioration (score de qualité)"

#: includes/Admin/Settings.php:403
msgid ""
"Photos scoring below this value (1–10) are automatically enhanced. Score 10 "
"= perfect photograph, 1 = technically unusable. Default: 7 — only visibly "
"problematic photos are processed. Set to 1 to disable automatic enhancement "
"entirely."
msgstr ""
"Les photos avec une note inférieure à cette valeur (1–10) sont "
"automatiquement améliorées. Score 10 = photo parfaite, 1 = techniquement "
"inutilisable. Par défaut : 7 — seules les photos visiblement problématiques "
"sont traitées. Mettre à 1 pour désactiver complètement l'amélioration "
"automatique."

#: includes/Admin/Settings.php:409
msgid "OpenAI API key"
msgstr "Clé API OpenAI"

#: includes/Admin/Settings.php:412
msgid "Required when OpenAI is the description or enhancement provider."
msgstr ""
"Requis lorsque OpenAI est le fournisseur de description ou d'amélioration."

#: includes/Admin/Settings.php:416
msgid "Anthropic API key"
msgstr "Clé API Anthropic"

#: includes/Admin/Settings.php:419
msgid "Required when Anthropic is the description provider."
msgstr "Requis lorsque Anthropic est le fournisseur de description."

#: includes/Admin/Settings.php:425
msgid "Artwork display width (px)"
msgstr "Largeur d'affichage de l'œuvre (px)"

#: includes/Admin/Settings.php:431
msgid ""
"Width of the agnosis-artwork image size used in post content and lightbox. "
"Height scales proportionally. Default: 1920. Existing images need to be "
"regenerated after changing this value."
msgstr ""
"Largeur de l'image agnosis-artwork utilisée dans le contenu du post et la "
"lightbox. La hauteur s'ajuste proportionnellement. Par défaut : 1920. Les "
"images existantes doivent être régénérées après avoir modifié cette valeur."

#: includes/Admin/Settings.php:435
msgid "Thumbnail size (px)"
msgstr "Taille de la miniature (px)"

#: includes/Admin/Settings.php:441
msgid ""
"Side length of the square agnosis-thumb size used in submission cards and "
"dashboard. Default: 512. Existing images need to be regenerated after "
"changing this value."
msgstr ""
"Longueur du côté de la miniature carrée agnosis-thumb utilisée dans les "
"cartes de soumission et le tableau de bord. Par défaut : 512. Les images "
"existantes doivent être régénérées après avoir modifié cette valeur."

#: includes/Admin/Settings.php:445
msgid "Email image width (px)"
msgstr "Largeur de l'image email (px)"

#: includes/Admin/Settings.php:451
msgid ""
"Width of the agnosis-email size used in artist notification emails. Height "
"scales proportionally — no cropping. Default: 420. Existing images need to "
"be regenerated after changing this value."
msgstr ""
"Largeur de la taille agnosis-email utilisée dans les emails de notification "
"aux artistes. La hauteur s'ajuste proportionnellement — pas de recadrage. "
"Par défaut : 420. Les images existantes doivent être régénérées après avoir "
"modifié cette valeur."

#: includes/Admin/Settings.php:457
msgid "Gallery overview — items per page"
msgstr "Aperçu de la galerie — éléments par page"

#: includes/Admin/Settings.php:463
msgid ""
"How many artwork cards the gallery overview shows per page. Pool is built "
"proportionally across all artists; featured artworks are preferred. Default: "
"12."
msgstr ""
"Combien de cartes d'œuvres la vue d'ensemble de la galerie affiche-t-elle "
"par page. Le pool est construit proportionnellement entre tous les artistes ;"
" les œuvres en vedette sont préférées. Par défaut : 12."

#: includes/Admin/Settings.php:469
msgid "System prompt"
msgstr "Invite système"

#: includes/Admin/Settings.php:474
msgid ""
"Sent to the AI as the system instruction. Use {tag_count} and {excerpt_words}"
" as tokens — they are replaced with the values below."
msgstr ""
"Envoyé à l'IA comme instruction système. Utilisez {tag_count} et "
"{excerpt_words} comme jetons — ils sont remplacés par les valeurs ci-dessous."

#: includes/Admin/Settings.php:478
msgid "Artist prompt template"
msgstr "Modèle d'invite pour l'artiste"

#: includes/Admin/Settings.php:483
msgid ""
"User message sent alongside the artwork image. Use {artist_prompt} where the "
"artist's own description should appear."
msgstr ""
"Message utilisateur envoyé avec l'image de l'œuvre. Utilisez {artist_prompt} "
"où la description de l'artiste doit apparaître."

#: includes/Admin/Settings.php:487
msgid "Enhancement instructions"
msgstr "Instructions d'amélioration"

#: includes/Admin/Settings.php:492
msgid ""
"Instructions passed to the image enhancement provider. The AI-generated "
"artwork description is appended automatically as context."
msgstr ""
"Instructions transmises au fournisseur d'amélioration d'image. La "
"description de l'œuvre générée par l'IA est automatiquement ajoutée en tant "
"que contexte."

#: includes/Admin/Settings.php:496
msgid "Number of tags"
msgstr "Nombre de tags"

#: includes/Admin/Settings.php:502
msgid ""
"How many tags the AI should generate per artwork. Referenced as {tag_count} "
"in the system prompt."
msgstr ""
"Combien de tags l'IA doit générer par œuvre. Référencé comme {tag_count} "
"dans l'invite système."

#: includes/Admin/Settings.php:506
msgid "Excerpt word limit"
msgstr "Limite de mots pour l'extrait"

#: includes/Admin/Settings.php:512
msgid ""
"Maximum words for the one-sentence excerpt. Referenced as {excerpt_words} in "
"the system prompt."
msgstr ""
"Nombre maximum de mots pour l'extrait en une phrase. Référencé comme "
"{excerpt_words} dans l'invite système."

#: includes/Admin/Settings.php:518
msgid "Enable ActivityPub federation"
msgstr "Activer la fédération ActivityPub"

#: includes/Admin/Settings.php:522
msgid "Broadcast new artworks to Mastodon, Pixelfed and the Fediverse."
msgstr "Diffuser les nouvelles œuvres sur Mastodon, Pixelfed et le Fediverse."

#: includes/Admin/Settings.php:527
msgid "Node public key"
msgstr "Clé publique du nœud"

#: includes/Admin/Settings.php:529
msgid ""
"Auto-generated RSA public key for this node. Share this with peer nodes."
msgstr ""
"Clé publique RSA générée automatiquement pour ce nœud. Partagez-la avec les "
"nœuds pairs."

#: includes/Admin/Settings.php:533
