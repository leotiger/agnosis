msgstr "عام"

#: includes/Admin/Settings.php:160
msgid "Email Inbox"
msgstr "صندوق البريد الإلكتروني"

#: includes/Admin/Settings.php:161
msgid "AI Providers"
msgstr "مزودو الذكاء الاصطناعي"

#: includes/Admin/Settings.php:162
msgid "Behaviour"
msgstr "السلوك"

#: includes/Admin/Settings.php:163
msgid "Network"
msgstr "الشبكة"

#: includes/Admin/Settings.php:164
