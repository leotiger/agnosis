#. translators: 1: sender's display name, 2: character count of their message, 3: configured character limit, 4: site name
#: includes/Artist/CommunityBroadcast.php:158
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"Your message to the community was %2$d characters long — the current limit "
"is %3$d. It was not sent to anyone.\n"
"\n"
"Every recipient's copy is translated individually into their own language, "
"so a very long message is costly to translate for the whole community. "
"Please shorten it and send it again.\n"
"\n"
"— %4$s"
msgstr ""
"नमस्ते %1$s,\n"
"\n"
"समुदाय को आपका संदेश %2$d वर्णों का था — वर्तमान सीमा %3$d है। इसे किसी को "
"नहीं भेजा गया।\n"
"\n"
"प्रत्येक प्राप्तकर्ता की प्रति उनकी अपनी भाषा में अलग-अलग अनूदित की जाती है, "
"इसलिए एक बहुत लंबा संदेश पूरे समुदाय के लिए अनुवाद करने में महँगा पड़ता है। "
"कृपया इसे छोटा करें और फिर से भेजें।\n"
"\n"
"— %4$s"

#. translators: %s: site name
#: includes/Artist/CommunityBroadcast.php:210
#, php-format
msgid "[%s] Your community message was not sent — no content found"
msgstr "[%s] आपका सामुदायिक संदेश नहीं भेजा गया — कोई सामग्री नहीं मिली"

#. translators: 1: sender's display name, 2: site name
#: includes/Artist/CommunityBroadcast.php:216
#, php-format
