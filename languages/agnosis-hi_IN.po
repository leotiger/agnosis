#: includes/Artist/DepartureNotification.php:360
#, php-format
msgid ""
"Hi %1$s,\n"
"\n"
"The %2$s community has opened a vote to remove a member. The vote closes on "
"%3$s.\n"
"\n"
"Cast your vote:\n"
"\n"
"Vote YES (remove): %4$s\n"
"\n"
"Vote NO (keep):    %5$s\n"
"\n"
"A majority of active members (more than 50%%) must vote yes for the removal "
"to proceed. You can change your vote by clicking the other link before the "
"deadline.\n"
"\n"
"— %2$s"
msgstr ""
"नमस्ते %1$s,\n"
"\n"
"%2$s समुदाय ने एक सदस्य को हटाने के लिए मतदान शुरू किया है। मतदान %3$s को समाप्त "
"होगा।\n"
"\n"
"अपना वोट डालें:\n"
"\n"
"हाँ वोट करें (हटाएँ): %4$s\n"
"\n"
"नहीं वोट करें (रखें):    %5$s\n"
"\n"
"हटाने की प्रक्रिया आगे बढ़ाने के लिए सक्रिय सदस्यों के बहुमत (50%% से अधिक) को हाँ में वोट "
"करना होगा। समय सीमा से पहले दूसरे लिंक पर क्लिक करके आप अपना वोट बदल सकते हैं।\n"
"\n"
"— %2$s"

