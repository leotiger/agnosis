#: includes/Admin/Settings.php:1711
#, php-format
msgid "Banned until %s"
msgstr "Baneado hasta el %s"

#: includes/Admin/Settings.php:1714
msgid "Banned"
msgstr "Baneado"

#: includes/Admin/Settings.php:1715
msgid "Active"
