msgstr ""
"No se pudo enviar el correo de prueba; revisa la dirección y la "
"configuración de correo saliente de tu sitio."

#: includes/Admin/Settings.php:152
msgid "Invitation sent."
msgstr "Invitación enviada."

#: includes/Admin/Settings.php:153
msgid ""
