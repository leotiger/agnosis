#: blocks/newsletter-signup/block.json
msgctxt "block title"
msgid "Newsletter Signup"
msgstr "Suscripción al boletín"

#: blocks/newsletter-signup/block.json
msgctxt "block description"
msgid ""
"Email signup form for the public newsletter (double opt-in). Submits to the "
"newsletter subscribe REST endpoint."
msgstr ""
"Formulario de suscripción por correo electrónico para el boletín público "
"(doble confirmación). Envía los datos al endpoint REST de suscripción al "
"boletín."

