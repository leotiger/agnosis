msgid "signup"
msgstr "registro"

#: blocks/submissions/block.json
msgctxt "block title"
msgid "My Submissions"
msgstr "Mis envíos"

#: blocks/submissions/block.json
msgctxt "block description"
msgid ""
"Lists the logged-in artist's pending artwork submissions for review and "
"approval. Place this on your /my-submissions/ page or in a Site Editor "
"template."
msgstr ""
"Lista los envíos de obras pendientes del artista conectado para su revisión "
"y aprobación. Colócalo en tu página /my-submissions/ o en una plantilla del "
"Editor del sitio."

