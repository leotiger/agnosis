msgstr "No hay ninguna dirección configurada"

#. translators: %s: site name
#: includes/Admin/Settings.php:1797
#, php-format
msgid "[TEST] Deliverability check from %s"
msgstr "[TEST] Comprobación de entregabilidad desde %s"

#: includes/Admin/Settings.php:1800
msgid ""
"This is a one-off deliverability test from your Agnosis Settings → Email "
"Inbox page. If you're reading this in your inbox (not spam), the "
"community/transactional From identity is deliverable to this address."
msgstr ""
"Esta es una prueba puntual de entregabilidad desde tu página Ajustes de "
