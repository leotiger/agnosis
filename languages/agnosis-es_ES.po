#: blocks/join/block.json
msgctxt "block title"
msgid "Join Agnosis"
msgstr "Únete a Agnosis"

#: blocks/join/block.json
msgctxt "block description"
msgid ""
"Public application form for artists who want to join the Agnosis network. "
"Submits to the admission REST endpoint. Place this on your /join/ page."
msgstr ""
"Formulario público de solicitud para artistas que quieren unirse a la red "
"Agnosis. Se envía al endpoint REST de admisión. Coloca esto en tu página /"
"join/."

#: blocks/join/block.json
