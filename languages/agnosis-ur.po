msgstr "آپ کا %s ہٹا دیا گیا ہے۔"

#: includes/Publishing/RemovalEndpoints.php:209
msgid "A valid removal token is required."
msgstr "ایک درست removal token درکار ہے۔"

#: includes/Publishing/RemovalEndpoints.php:235
msgid "No pending removal request found for this item."
msgstr "اس آئٹم کے لیے کوئی pending removal request نہیں ملی۔"

#: includes/Publishing/RemovalEndpoints.php:247
msgid "The removal link has expired. Please send another removal request."
msgstr ""
"حذف کرنے کا لنک ختم ہو چکا ہے۔ براہِ کرم حذف کرنے کی ایک اور درخواست بھیجیں۔"

#: includes/Publishing/RemovalEndpoints.php:255
msgid "Invalid removal token."
msgstr "غلط removal token۔"

#: includes/Publishing/ReviewConfirm.php:253
msgid "View it live"
msgstr "اسے لائیو دیکھیں"

