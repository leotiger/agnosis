#: includes/Admin/Settings.php:159
msgid "General"
msgstr "عام"

#: includes/Admin/Settings.php:160
msgid "Email Inbox"
msgstr "ای میل ان باکس"

#: includes/Admin/Settings.php:161
msgid "AI Providers"
msgstr "AI فراہم کنندگان"

#: includes/Admin/Settings.php:162
msgid "Behaviour"
msgstr "رویہ"

#: includes/Admin/Settings.php:163
msgid "Network"
msgstr "نیٹ ورک"

#: includes/Admin/Settings.php:164
