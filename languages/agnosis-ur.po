msgid "Event published"
msgstr "ایونٹ شائع ہو گیا"

#: includes/Publishing/ReviewConfirm.php:297
msgid "The event has been published."
msgstr "ایونٹ شائع ہو گیا ہے۔"

#: includes/Publishing/ReviewConfirm.php:298
msgid "Artwork published"
msgstr "فن پارہ شائع ہو گیا"

#: includes/Publishing/ReviewConfirm.php:298
msgid "The artwork has been published to the gallery."
msgstr "آرٹ ورک گیلری میں شائع کر دیا گیا ہے۔"

#: includes/Publishing/ReviewConfirm.php:299
msgid "Submission discarded"
msgstr "جمع کروانا مسترد کر دیا گیا"

#: includes/Publishing/ReviewConfirm.php:299
