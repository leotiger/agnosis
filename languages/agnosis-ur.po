#. translators: 1: queue rows reset, 2: messages newly enqueued
#: includes/Admin/Settings.php:80
#, php-format
msgid ""
"Force-reprocess complete. %1$d queue row(s) reset, %2$d new message(s) "
"enqueued. Click \"Process Pending Queue\" to run the AI pipeline."
msgstr ""
"مکمل دوبارہ پروسیس کریں۔ %1$d قطاریں ری سیٹ کی گئی ہیں، %2$d نئی پیغامات "
"شامل کی گئی ہیں۔ \"پینڈنگ قطاریں پروسیس کریں\" پر کلک کریں تاکہ AI پائپ لائن "
"چلائی جائے۔"

#: includes/Admin/Settings.php:88
msgid "Log cleared."
msgstr "لاگ صاف کیا گیا۔"

#. translators: %d: number of queue items processed
#: includes/Admin/Settings.php:96
#, php-format
msgid "Processed %d pending queue item(s). Check the Logs tab for details."
msgstr ""
"%d زیر التواء قطار آئٹمز پروسیس کی گئی۔ تفصیلات کے لیے لاگز ٹیب چیک کریں۔"

#. translators: %d: number of new messages enqueued
#: includes/Admin/Settings.php:106
#, php-format
msgid ""
"Poll complete. %d new message(s) enqueued. Check the Logs tab, then click "
"Process Pending Queue."
msgstr ""
"پول مکمل۔ %d نئی پیغامات شامل کی گئی ہیں۔ لاگز ٹیب چیک کریں، پھر \"پینڈنگ "
"قطاریں پروسیس کریں\" پر کلک کریں۔"

