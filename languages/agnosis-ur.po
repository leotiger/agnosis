#, php-format
msgid "Could not remove the %s. Please try again."
msgstr "%s کو ہٹایا نہیں جا سکا۔ براہِ کرم دوبارہ کوشش کریں۔"

#. translators: %s: "artwork" or "event"
#: includes/Publishing/RemovalEndpoints.php:137
#, php-format
msgid "Your %s has been removed."
msgstr "آپ کا %s ہٹا دیا گیا ہے۔"

#: includes/Publishing/RemovalEndpoints.php:180
msgid "A valid removal token is required."
msgstr "ہٹانے کے لیے ایک درست ٹوکن درکار ہے۔"

#: includes/Publishing/RemovalEndpoints.php:192
msgid "No pending removal request found for this item."
msgstr "اس آئٹم کے لیے ہٹانے کی کوئی زیرِ التوا درخواست نہیں ملی۔"

#: includes/Publishing/RemovalEndpoints.php:204
msgid "The removal link has expired. Please send another removal request."
msgstr "ہٹانے کا لنک ختم ہو چکا ہے۔ براہِ کرم ہٹانے کی ایک اور درخواست بھیجیں۔"

#: includes/Publishing/RemovalEndpoints.php:212
msgid "Invalid removal token."
msgstr "غلط ہٹانے کا ٹوکن۔"

#: includes/Publishing/ReviewConfirm.php:126
msgid "Artwork published"
msgstr "فن پارہ شائع ہو گیا"

#: includes/Publishing/ReviewConfirm.php:127
msgid "Submission discarded"
msgstr "سبمیشن مسترد کر دی گئی"

#: includes/Publishing/ReviewConfirm.php:128
msgid "Artwork removed"
msgstr "فن پارہ ہٹا دیا گیا"

#: includes/Publishing/ReviewConfirm.php:129
msgid "Link expired or already used"
msgstr "لنک ختم ہو چکا ہے یا پہلے ہی استعمال ہو چکا ہے"

#: includes/Publishing/ReviewConfirm.php:133
msgid "The artwork has been published to the gallery."
msgstr "فن پارہ گیلری میں شائع کر دیا گیا ہے۔"

#: includes/Publishing/ReviewConfirm.php:134
msgid "The submission has been discarded."
msgstr "سبمیشن مسترد کر دی گئی ہے۔"

#: includes/Publishing/ReviewConfirm.php:135
msgid "Your artwork has been removed from the gallery."
msgstr "آپ کا فن پارہ گیلری سے ہٹا دیا گیا ہے۔"

#: includes/Publishing/ReviewConfirm.php:136
msgid ""
"This link may have already been used or may have expired. Please log in to "
"manage your submissions."
msgstr ""
"ممکن ہے یہ لنک پہلے ہی استعمال ہو چکا ہو یا اس کی مدت ختم ہو گئی ہو۔ براہِ "
"کرم اپنی سبمیشنز منظم کرنے کے لیے لاگ اِن کریں۔"

#: includes/Publishing/ReviewConfirm.php:177
msgid "Publish this artwork?"
msgstr "کیا یہ فن پارہ شائع کرنا ہے؟"

#: includes/Publishing/ReviewConfirm.php:178
msgid "This will make the submission visible in the gallery."
msgstr "اس سے سبمیشن گیلری میں نظر آنے لگے گی۔"

#: includes/Publishing/ReviewConfirm.php:179
msgid "Yes, publish it"
msgstr "جی ہاں، اسے شائع کریں"

#: includes/Publishing/ReviewConfirm.php:182
msgid "Discard this submission?"
msgstr "کیا یہ سبمیشن مسترد کرنی ہے؟"

#: includes/Publishing/ReviewConfirm.php:183
msgid ""
"This will permanently discard the submission — it will not be published."
msgstr ""
"اس سے سبمیشن مستقل طور پر مسترد ہو جائے گی — اسے شائع نہیں کیا جائے گا۔"

#: includes/Publishing/ReviewConfirm.php:184
msgid "Yes, discard it"
msgstr "جی ہاں، اسے مسترد کریں"

#: includes/Publishing/ReviewConfirm.php:187
msgid "Remove this artwork?"
msgstr "کیا یہ فن پارہ ہٹانا ہے؟"

#: includes/Publishing/ReviewConfirm.php:188
msgid "This will remove the published artwork from the gallery."
msgstr "اس سے شائع شدہ فن پارہ گیلری سے ہٹ جائے گا۔"

#: includes/Publishing/ReviewConfirm.php:189
msgid "Yes, remove it"
msgstr "جی ہاں، اسے ہٹا دیں"

#: includes/Publishing/ReviewEndpoints.php:85
#: includes/Publishing/ReviewEndpoints.php:146
#: includes/Publishing/ReviewEndpoints.php:185
msgid "Submission not found."
msgstr "سبمیشن نہیں ملی۔"

#: includes/Publishing/ReviewEndpoints.php:94
#: includes/Publishing/ReviewEndpoints.php:155
#: includes/Publishing/ReviewEndpoints.php:194
msgid "This submission is not awaiting review."
msgstr "یہ سبمیشن ابھی جائزے کی منتظر نہیں ہے۔"

#: includes/Publishing/ReviewEndpoints.php:294
msgid "You do not have permission to review this submission."
msgstr "آپ کو اس سبمیشن کا جائزہ لینے کی اجازت نہیں ہے۔"

#: includes/Publishing/ReviewEndpoints.php:313
msgid "Review link not found or already used."
msgstr "جائزے کا لنک نہیں ملا یا پہلے ہی استعمال ہو چکا ہے۔"

#: includes/Publishing/ReviewEndpoints.php:321
msgid "Invalid review token."
