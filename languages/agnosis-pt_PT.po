#, php-format
msgid ""
"Force-reprocess complete. %1$d queue row(s) reset, %2$d new message(s) "
"enqueued. Click \"Process Pending Queue\" to run the AI pipeline."
msgstr ""
"Reprocessamento forçado concluído. %1$d linha(s) da fila redefinidas, %2$d "
"nova(s) mensagem(ns) enfileirada(s). Clique em \"Processar Fila Pendente\" "
"para executar o pipeline de IA."

#: includes/Admin/Settings.php:88
msgid "Log cleared."
msgstr "Registo limpo."

#. translators: %d: number of queue items processed
#: includes/Admin/Settings.php:96
#, php-format
