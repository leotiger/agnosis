msgid "popover"
msgstr "popover"

#: blocks/newsletter-popover/block.json
msgctxt "block keyword"
msgid "footer"
msgstr "rodapé"

#: blocks/newsletter-signup/block.json
msgctxt "block title"
msgid "Newsletter Signup"
msgstr "Registo na newsletter"

#: blocks/newsletter-signup/block.json
msgctxt "block description"
msgid ""
"Email signup form for the public newsletter (double opt-in). Submits to the "
"newsletter subscribe REST endpoint."
msgstr ""
"Formulário de registo por email para a newsletter pública (double opt-in). "
"Submete para o endpoint REST de subscrição da newsletter."

#: blocks/newsletter-signup/block.json
msgctxt "block keyword"
msgid "signup"
msgstr "registo"

#: blocks/submissions/block.json
msgctxt "block title"
msgid "My Submissions"
msgstr "As minhas submissões"

#: blocks/submissions/block.json
msgctxt "block description"
msgid ""
"Lists the logged-in artist's pending artwork submissions for review and "
"approval. Place this on your /my-submissions/ page or in a Site Editor "
"template."
msgstr ""
"Lista as submissões de obras pendentes do artista com sessão iniciada para "
"revisão e aprovação. Coloca isto na tua página /my-submissions/ ou num "
"template do Editor do Site."

#: blocks/submissions/block.json
msgctxt "block keyword"
msgid "submissions"
msgstr "submissões"

#: blocks/submissions/block.json
