msgstr "Limpar todas as entradas do registo?"

#: includes/Admin/Settings.php:1266
msgid "Clear All"
msgstr "Limpar tudo"

#. translators: %d: total log entry count
#: includes/Admin/Settings.php:1275
#, php-format
msgid ""
"%d entries total. Logs are pruned automatically according to the Inbox "
"retention setting."
msgstr ""
"%d entradas no total. Os registos são limpos automaticamente de acordo com a "
"definição de retenção da Caixa de Entrada."

#: includes/Admin/Settings.php:1282
msgid "No log entries yet."
msgstr "Ainda não há entradas de registo."

#: includes/Admin/Settings.php:1287
