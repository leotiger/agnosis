msgid "contact"
msgstr "contacto"

#: blocks/breadcrumb-icon-link/block.json
msgctxt "block keyword"
msgid "language"
msgstr "idioma"

#: blocks/breadcrumb-icon-link/block.json
msgctxt "block keyword"
msgid "icon"
msgstr "ícone"

#: blocks/contact-form/block.json
msgctxt "block title"
msgid "Artist Contact Form"
msgstr "Formulário de contacto do artista"

#: blocks/contact-form/block.json
msgctxt "block description"
msgid ""
"Contact form letting a visitor message the current artist subdomain's "
"artist. Submits to a per-artist REST endpoint; the message is moderated, "
"translated into the artist's own language, and emailed to them."
msgstr ""
"Formulário de contacto que permite a um visitante enviar uma mensagem ao "
"artista do subdomínio atual. Submete para um endpoint REST por artista; a "
"mensagem é moderada, traduzida para a própria língua do artista e enviada "
"por email."

#: blocks/contact-form/block.json
msgctxt "block keyword"
msgid "message"
msgstr "mensagem"

#: blocks/contact-form/block.json blocks/newsletter-signup/block.json
msgctxt "block keyword"
msgid "email"
msgstr "email"

#: blocks/gallery-overview/block.json
msgctxt "block title"
msgid "Agnosis Gallery Overview"
msgstr "Vista geral da galeria da Agnosis"

#: blocks/gallery-overview/block.json
msgctxt "block description"
msgid ""
"Proportional, randomized artwork grid across all artists. Shows featured "
"artworks first, respects per-artist budget, supports medium filtering and "
"pagination."
msgstr ""
"Grelha proporcional e aleatória de obras de todos os artistas. Mostra "
"primeiro as obras em destaque, respeita o orçamento por artista, suporta "
"filtragem por meio e paginação."

#: blocks/gallery-overview/block.json
msgctxt "block keyword"
msgid "gallery"
msgstr "galeria"

#: blocks/gallery-overview/block.json
msgctxt "block keyword"
msgid "artists"
msgstr "artistas"

#: blocks/gallery-overview/block.json
msgctxt "block keyword"
msgid "overview"
msgstr "vista geral"

#: blocks/join/block.json
msgctxt "block title"
msgid "Join Agnosis"
msgstr "Junta-te à Agnosis"

#: blocks/join/block.json
msgctxt "block description"
msgid ""
"Public application form for artists who want to join the Agnosis network. "
"Submits to the admission REST endpoint. Place this on your /join/ page."
msgstr ""
"Formulário público de candidatura para artistas que queiram juntar-se à rede"
" Agnosis. Submete para o endpoint REST de admissão. Coloca isto na tua "
"página /join/."

#: blocks/join/block.json
msgctxt "block keyword"
msgid "join"
msgstr "juntar-se"

#: blocks/join/block.json
