msgid "Artwork published"
msgstr "Karya diterbitkan"

#: includes/Publishing/ReviewConfirm.php:298
msgid "The artwork has been published to the gallery."
msgstr "Karya telah diterbitkan ke galeri."

#: includes/Publishing/ReviewConfirm.php:299
msgid "Submission discarded"
msgstr "Kiriman dibuang"

#: includes/Publishing/ReviewConfirm.php:299
msgid "The submission has been discarded."
msgstr "Kiriman telah dibuang."

#: includes/Publishing/ReviewConfirm.php:300
msgid "Biography removed"
msgstr "Biografi dihapus"

#: includes/Publishing/ReviewConfirm.php:300
msgid "Your biography has been removed."
msgstr "Biografi Anda telah dihapus."

#: includes/Publishing/ReviewConfirm.php:301
msgid "Event removed"
msgstr "Acara dihapus"

#: includes/Publishing/ReviewConfirm.php:301
msgid "The event has been removed."
msgstr "Acara telah dihapus."

#: includes/Publishing/ReviewConfirm.php:302
msgid "Artwork removed"
msgstr "Karya dihapus"

#: includes/Publishing/ReviewConfirm.php:302
msgid "Your artwork has been removed from the gallery."
msgstr "Karya Anda telah dihapus dari galeri."

#: includes/Publishing/ReviewConfirm.php:303
msgid ""
"This link may have already been used or may have expired. Please log in to "
