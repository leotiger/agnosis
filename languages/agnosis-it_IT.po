msgstr "Iscritto"

#. translators: %s: date until which the artist is banned
#: includes/Admin/Settings.php:1626
#, php-format
msgid "Banned until %s"
msgstr "Bloccato fino al %s"

#: includes/Admin/Settings.php:1629
msgid "Banned"
msgstr "Bloccato"

#: includes/Admin/Settings.php:1630
msgid "Active"
msgstr "Attivo"

#: includes/Admin/Settings.php:1650
msgid "Leave the date blank to ban indefinitely. Continue?"
msgstr "Lascia la data vuota per bloccare a tempo indeterminato. Continuare?"

#: includes/Admin/Settings.php:1655
msgid "Leave blank to ban indefinitely"
msgstr "Lascia vuoto per bloccare a tempo indeterminato"

#: includes/Admin/Settings.php:1657
msgid "Suspend"
msgstr "Sospendi"

#: includes/Admin/Settings.php:1663
msgid ""
"Permanently delete this artist and all their content? This cannot be undone."
msgstr ""
"Eliminare definitivamente questo artista e tutti i suoi contenuti? Questa "
"operazione non può essere annullata."

#: includes/Admin/Settings.php:1673
msgid ""
"Open a community removal vote for this artist? All members will be emailed."
msgstr ""
"Aprire una votazione comunitaria per rimuovere questo artista? Tutti i "
"membri riceveranno un'email."

#: includes/Admin/Settings.php:1677
msgid "Open Vote"
msgstr "Apri votazione"

#: includes/Admin/Settings.php:1833
msgid "Newsletter Status"
msgstr "Stato newsletter"

#. translators: 1: confirmed public subscriber count, 2: configured comfort threshold
#: includes/Admin/Settings.php:1842
#, php-format
msgid ""
"You have %1$d confirmed public subscribers, above the configured comfort "
