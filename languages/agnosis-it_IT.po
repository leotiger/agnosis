#: blocks/join/block.json
msgctxt "block title"
msgid "Join Agnosis"
msgstr "Unisciti ad Agnosis"

#: blocks/join/block.json
msgctxt "block description"
msgid ""
"Public application form for artists who want to join the Agnosis network. "
"Submits to the admission REST endpoint. Place this on your /join/ page."
msgstr ""
"Modulo di candidatura pubblica per gli artisti che desiderano unirsi alla "
"rete Agnosis. Invia all'endpoint REST di ammissione. Inseriscilo nella tua "
"pagina /join/."

