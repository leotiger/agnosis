msgstr ""
"Tutto pronto — da ora in poi la newsletter arriverà nella tua casella di "
"posta."

#: includes/Newsletter/SubscriptionConfirm.php:164
#: includes/Newsletter/SubscriptionConfirm.php:185
msgid "Unsubscribed"
msgstr "Disiscritto"

#: includes/Newsletter/SubscriptionConfirm.php:164
msgid "You will no longer receive the newsletter. Sorry to see you go."
msgstr "Non riceverai più la newsletter. Ci dispiace vederti andare via."

#: includes/Newsletter/SubscriptionConfirm.php:166
