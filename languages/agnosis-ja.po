msgstr "イベントを公開しました。"

#: includes/Publishing/ReviewConfirm.php:298
msgid "Artwork published"
msgstr "作品公開済み"

#: includes/Publishing/ReviewConfirm.php:298
msgid "The artwork has been published to the gallery."
msgstr "作品はギャラリーに公開されました。"

#: includes/Publishing/ReviewConfirm.php:299
msgid "Submission discarded"
msgstr "送信内容を破棄しました"

#: includes/Publishing/ReviewConfirm.php:299
msgid "The submission has been discarded."
msgstr "送信内容を破棄しました。"

#: includes/Publishing/ReviewConfirm.php:300
msgid "Biography removed"
msgstr "プロフィール削除済み"

#: includes/Publishing/ReviewConfirm.php:300
