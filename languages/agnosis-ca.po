msgstr ""
"[Agnosis] Hi ha diversos elements titulats «%s» — trieu quin voleu eliminar"

#. translators: %s: site name
#: includes/Publishing/Notification.php:175
#, php-format
msgid "[%s] We couldn't find that artwork or event"
msgstr "[%s] No hem pogut trobar aquesta obra o esdeveniment"

#. translators: %s: site name
#: includes/Publishing/Notification.php:234
#, php-format
msgid "[%s] Your artwork is now featured"
msgstr "[%s] La teva obra ara està destacada"

#. translators: %s: site name
#: includes/Publishing/Notification.php:241
#, php-format
