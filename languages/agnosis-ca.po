msgstr "Començaràs a rebre el butlletí un cop ho confirmis a continuació."

#: includes/Newsletter/SubscriptionConfirm.php:206
msgid "Unsubscribe from the newsletter?"
msgstr "Cancel·lar la subscripció al butlletí?"

#: includes/Newsletter/SubscriptionConfirm.php:207
msgid "You will stop receiving the newsletter once you confirm below."
msgstr "Deixaràs de rebre el butlletí un cop ho confirmis a continuació."

#: includes/Newsletter/SubscriptionConfirm.php:208
msgid "Confirm unsubscribe"
msgstr "Confirma la cancel·lació de la subscripció"

#: includes/Publishing/EmbedPolicy.php:119
