msgid "Please select your language."
msgstr "Lütfen dilinizi seçin."

#: includes/Artist/Admission.php:237
msgid "An account with this email address already exists."
msgstr "Bu e-posta adresiyle zaten bir hesap mevcut."

#: includes/Artist/Admission.php:261
msgid "This email address belongs to an admitted artist."
msgstr "Bu e-posta adresi kabul edilmiş bir sanatçıya ait."

#: includes/Artist/Admission.php:262
msgid "An application for this email address is already pending."
msgstr "Bu e-posta adresi için bir başvuru zaten beklemede."

#: includes/Artist/Admission.php:609 includes/Artist/Admission.php:717
msgid "Application not found."
msgstr "Başvuru bulunamadı."

#: includes/Artist/Admission.php:649
msgid "Only admitted artists can vouch."
msgstr "Yalnızca kabul edilmiş sanatçılar referans olabilir."

#: includes/Artist/Admission.php:659
msgid "Admin access required."
msgstr "Yönetici erişimi gerekli."

#: includes/Artist/Admission.php:698
msgid ""
"Community voting is disabled on this site. Applications are reviewed "
"directly by an admin."
msgstr ""
"Bu sitede topluluk oylaması devre dışı. Başvurular doğrudan bir yönetici "
"tarafından incelenir."

#: includes/Artist/Admission.php:731
msgid "You cannot vote on your own application."
msgstr "Kendi başvurunuza oy veremezsiniz."

#: includes/Artist/AdmissionConfirm.php:64
#: includes/Newsletter/SubscriptionConfirm.php:82
#: includes/Newsletter/SubscriptionConfirm.php:139
