.DS_Store
**/.DS_Store

# Dev tooling lives in dev/. Heavy install artefacts (vendor/, node_modules/,
# caches) are ignored by dev/.gitignore. Running `composer install` in the
# root IS required (it builds vendor-prefixed/, which dev/bootstrap.php
# needs even for unit tests — CONTRIBUTING.md's Development setup); these
# entries just mean its own build output never gets committed, same as
# dev/vendor/ and node_modules/ never are.
/vendor/
/vendor-prefixed/
/node_modules/
/build/

# Strauss (dependency-prefixing tool, C-item/§4e) — downloaded on demand by
# the "prefix-namespaces" composer script, not committed.
/bin/strauss.phar
.phpcs.cache
.phpunit.result.cache
.phpstan.cache
/.wp-env/
composer.lock
package-lock.json

# Editor / IDE.
.vscode/
.idea/
*.swp
*~

# Local gitleaks/trufflehog scan reports (H-2, AUDIT-0.9.39.md §4) — a
# point-in-time verification artifact, not source; it goes stale the moment
# another commit lands, and the durable record of "scan ran, here's the
# result" belongs in agnosis-audit's AUDIT-*.md, not a JSON blob here. Same
# reasoning as dev/coverage/ (H-1): generated output, no reason to be
# tracked at all — belt-and-braces .distignore entry too, in case one is
# ever force-added.
gitleaks-*.json

# Secrets / local overrides — never commit.
.env
.env.local
