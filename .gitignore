.DS_Store
**/.DS_Store

# Dev tooling lives in dev/. Heavy install artefacts (vendor/, node_modules/,
# caches) are ignored by dev/.gitignore. The entries below guard against
# anyone accidentally running composer install or npm install in the root.
/vendor/
/node_modules/
/build/
/coverage/
.phpcs.cache
.phpunit.result.cache
.phpstan.cache
/.wp-env/
composer.lock
package-lock.json

# Editor / IDE.
.vscode/
.idea/
*.swp
*~

# Languages — compiled binaries are generated by compile-pos.sh, not committed.
# Commit only .pot and .po source files.
/languages/*.mo
/languages/*.l10n.php

# Secrets / local overrides — never commit.
.env
.env.local
